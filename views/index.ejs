<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notes Creator</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body
    class="min-h-screen bg-gradient-to-br from-pink-200 via-purple-200 to-fuchsia-300 flex items-center justify-center p-10"
  >
    <div
      class="w-full max-w-6xl bg-white/40 backdrop-blur-lg rounded-3xl shadow-2xl p-10 border border-white/30"
    >
      <!-- Heading -->
      <div class="mb-10">
        <h1 class="text-5xl font-bold text-purple-900 tracking-tight">
          Notes Creator
        </h1>
        <p class="text-purple-700 mt-2 text-lg">
          Create soft beautiful notes with Hydrangea vibes 🌸
        </p>
      </div>

      <!-- Form -->
      <form action="/create" method="POST" class="space-y-5">
        <!-- Title -->
        <input
          type="text"
          name="title"
          placeholder="Enter note title..."
          class="w-full px-5 py-4 rounded-2xl bg-white/70 border border-pink-200 outline-none focus:ring-4 focus:ring-pink-300 text-purple-900 placeholder-purple-400 text-lg"
        />

        <!-- Description -->
        <textarea
          name="description"
          rows="5"
          placeholder="Write your note description..."
          class="w-full px-5 py-4 rounded-2xl bg-white/70 border border-pink-200 outline-none resize-none focus:ring-4 focus:ring-fuchsia-300 text-purple-900 placeholder-purple-400 text-lg"
        ></textarea>

        <!-- Button -->
        <button
          type="submit"
          class="bg-gradient-to-r from-pink-400 to-fuchsia-500 hover:scale-[1.02] transition-all duration-300 text-white px-8 py-3 rounded-2xl text-lg font-semibold shadow-lg"
        >
          Create Note
        </button>
      </form>

      <!-- Notes Section -->
      <div class="mt-14">
        <h2 class="text-3xl font-bold text-purple-900 mb-6">Your Notes</h2>

        <div class="flex flex-wrap gap-6">
          <!-- Card -->
           <% if (files.length > 0){ %>
           <% files.forEach((file) => { %>
          <div
            class="w-72 bg-white/60 backdrop-blur-md rounded-2xl p-5 shadow-lg border border-pink-100 hover:translate-y-[-5px] transition-all duration-300"
          >
            <h3 class="text-2xl font-bold text-purple-900"><%= file %></h3>

            <p class="text-purple-700 mt-2 line-clamp-3">
              Complete backend learning and revise Express routing concepts.
            </p>
            <div class=" flex items-center">
               <a
              href="/file/<%= file%>"
              class="inline-block mt-4 text-pink-600 font-semibold hover:text-fuchsia-700"
            >
              Read More →
            </a>
            <a
              href="/edit/<%= file%>"
              class="inline-block mt-4 ml-4 text-red-500 font-semibold hover:text-red-700"
              >
            Edit
          </a>
  
            </div>
           
          </div>
          <% }) %>
          <% } else { %>
          <div class="w-full bg-white/60 backdrop-blur-md rounded-2xl p-5 shadow-lg border border-pink-100 text-center">
            <p class="text-purple-700">
              No notes available. Create your first note!
            </p>
            </div>
            <% } %>
        </div>
      </div>
    </div>
  </body>
</html>
