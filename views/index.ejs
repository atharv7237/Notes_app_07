<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notes Creator</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>

  <body class="min-h-screen bg-gradient-to-br from-pink-200 via-purple-200 to-fuchsia-300 relative overflow-x-hidden">

  <!-- Decorative Blobs -->

  <div class="fixed top-0 left-0 w-96 h-96 bg-pink-400/30 blur-3xl rounded-full"></div>
  <div class="fixed bottom-0 right-0 w-96 h-96 bg-fuchsia-400/30 blur-3xl rounded-full"></div>

  <!-- Logout -->

  <div class="absolute top-6 left-6 z-50">
    <a href="/logout">
      <button
        class="bg-gradient-to-r from-pink-500 to-fuchsia-500 hover:scale-105 transition-all duration-300 text-white px-6 py-3 rounded-2xl font-semibold shadow-xl"
      >
        Logout
      </button>
    </a>
  </div>

  <div class="max-w-7xl mx-auto px-6 py-10">

<!-- Hero Header -->
<div class="text-center mb-12">
  <h1
    class="text-6xl font-extrabold bg-gradient-to-r from-purple-900 via-fuchsia-700 to-pink-500 bg-clip-text text-transparent"
  >
    Notes Creator
  </h1>

  <p class="text-purple-700 text-lg mt-4">
    Organize your thoughts, ideas and memories beautifully 🌸
  </p>
</div>

<!-- Form Card -->
<div
  class="bg-white/40 backdrop-blur-xl border border-white/50 rounded-3xl shadow-2xl p-8 mb-12"
>

  <form action="/create" method="POST" class="space-y-5">

    <input
      type="text"
      name="title"
      placeholder="✨ Enter note title..."
      class="w-full px-6 py-4 rounded-2xl bg-white/70 border border-pink-200 outline-none focus:ring-4 focus:ring-pink-300 text-purple-900 placeholder-purple-400 text-lg"
    />

    <input
      type="text"
      name="user"
      value="<%= user %>"
      hidden
    />

    <textarea
      name="description"
      rows="5"
      placeholder="💭 Write your thoughts..."
      class="w-full px-6 py-4 rounded-2xl bg-white/70 border border-pink-200 outline-none resize-none focus:ring-4 focus:ring-fuchsia-300 text-purple-900 placeholder-purple-400 text-lg"
    ></textarea>

    <div class="flex justify-center">
      <button
        type="submit"
        class="bg-gradient-to-r from-pink-500 to-fuchsia-500 hover:scale-105 hover:shadow-2xl transition-all duration-300 text-white px-12 py-4 rounded-2xl text-lg font-bold shadow-lg"
      >
        ➕ Create Note
      </button>
    </div>

  </form>
</div>

<!-- Notes Section -->
<div>

  <div class="flex items-center justify-center mb-10">
    <h2 class="text-4xl font-bold text-purple-900">
      Your Notes ✨
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

    <% if (Notes.length > 0){ %>
    <% Notes.forEach((file) => { %>

    <div
      class="bg-white/50 backdrop-blur-xl rounded-3xl p-6 shadow-xl border border-white/40 hover:-translate-y-3 hover:shadow-2xl transition-all duration-300"
    >

      <h3 class="text-2xl font-bold text-purple-900 mb-3">
        <%= file.title %>
      </h3>

      <p class="text-purple-700 leading-relaxed">
        <%= file.description.substring(0,100) %>...
      </p>

      <div class="flex items-center gap-5 mt-6">

        <a
          href="/file/<%= file._id %>"
          class="text-pink-600 font-semibold hover:text-fuchsia-700"
        >
          Read More →
        </a>

        <a
          href="/edit/<%= file._id %>"
          class="text-red-500 font-semibold hover:text-red-700"
        >
          Edit
        </a>

         <a
          href="/delete/<%= file._id %>"
          class="text-red-500 font-semibold hover:text-red-700"
        >
          Delete
        </a>
      </div>

    </div>

    <% }) %>

    <% } else { %>

    <div
      class="col-span-full bg-white/50 backdrop-blur-xl rounded-3xl p-10 shadow-xl border border-white/40 text-center"
    >
      <h3 class="text-2xl font-bold text-purple-900">
        No Notes Yet 🌸
      </h3>

      <p class="text-purple-700 mt-3">
        Create your first beautiful note and start organizing your ideas.
      </p>
    </div>

    <% } %>

  </div>

</div>

  </div>

</body>
</html>
