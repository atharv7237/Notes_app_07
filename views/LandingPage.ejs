<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NoteVault</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-gradient-to-br from-pink-200 via-purple-200 to-fuchsia-300">

    <!-- Navbar -->
    <nav class="flex items-center justify-between px-10 py-6">
        <h1 class="text-3xl font-bold text-purple-900 shadow-lg">
            NoteVault
        </h1>

        <div class="flex gap-4">
            <a href="/loginPage"
                class="px-5 py-2 rounded-xl bg-white/40 backdrop-blur-md border border-white/40 text-purple-900 font-semibold hover:scale-105 transition">
                Login
            </a>

            <a href="/register"
                class="px-5 py-2 rounded-xl bg-gradient-to-r from-pink-400 to-fuchsia-500 text-white font-semibold hover:scale-105 transition">
                Register
            </a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-10 py-16">

        <div class="grid md:grid-cols-2 gap-12 items-center">

            <!-- Left -->
            <div>
                <h1 class="text-6xl font-bold text-purple-900 leading-tight">
                    Your Personal
                    <span class="text-fuchsia-600">
                        Notes Vault
                    </span>
                </h1>

                <p class="mt-6 text-xl text-purple-700 leading-relaxed">
                    Capture ideas, organize thoughts, and securely manage
                    your notes from anywhere.
                </p>

                <div class="flex gap-4 mt-8">
                    <a href="/register"
                        class="px-8 py-4 rounded-2xl bg-gradient-to-r from-pink-400 to-fuchsia-500 text-white font-semibold shadow-lg hover:scale-105 transition">
                        Get Started
                    </a>

                    <a href="/loginPage"
                        class="px-8 py-4 rounded-2xl bg-white/50 backdrop-blur-md border border-white/50 text-purple-900 font-semibold hover:scale-105 transition">
                        Login
                    </a>
                </div>
            </div>

            <!-- Right Mock Card -->
            <div class="flex justify-center">

                <div
                    class="w-full max-w-md bg-white/40 backdrop-blur-lg rounded-3xl p-8 shadow-2xl border border-white/30">

                    <h2 class="text-2xl font-bold text-purple-900">
                        📒 Learning JWT
                    </h2>

                    <ul class="mt-6 space-y-3 text-purple-700">
                        <li>✅ Understand JWT Sign</li>
                        <li>✅ Understand JWT Verify</li>
                        <li>✅ Store Token in Cookies</li>
                        <li>✅ Protect Routes</li>
                        <li>✅ User Authentication</li>
                    </ul>

                    <div class="mt-6 text-sm text-purple-500">
                        Last Updated • Today
                    </div>
                </div>

            </div>

        </div>

    </section>

    <!-- Features -->
    <section class="max-w-7xl mx-auto px-10 py-10">

        <h2 class="text-4xl font-bold text-center text-purple-900 mb-12">
            Why Use NoteVault?
        </h2>

        <div class="grid md:grid-cols-3 gap-8">

            <div
                class="bg-white/40 backdrop-blur-lg rounded-3xl p-8 shadow-xl border border-white/30">
                <h3 class="text-2xl font-bold text-purple-900">
                    📒 Create Notes
                </h3>

                <p class="mt-4 text-purple-700">
                    Quickly create and organize your notes in one place.
                </p>
            </div>

            <div
                class="bg-white/40 backdrop-blur-lg rounded-3xl p-8 shadow-xl border border-white/30">
                <h3 class="text-2xl font-bold text-purple-900">
                    🔒 Secure Access
                </h3>

                <p class="mt-4 text-purple-700">
                    Your notes are protected using authentication and
                    encrypted passwords.
                </p>
            </div>

            <div
                class="bg-white/40 backdrop-blur-lg rounded-3xl p-8 shadow-xl border border-white/30">
                <h3 class="text-2xl font-bold text-purple-900">
                    ☁️ Access Anywhere
                </h3>

                <p class="mt-4 text-purple-700">
                    Login from any device and continue where you left off.
                </p>
            </div>

        </div>

    </section>

    <!-- About Project -->
    <section class="max-w-5xl mx-auto px-10 py-16">

        <div
            class="bg-white/40 backdrop-blur-lg rounded-3xl p-10 shadow-2xl border border-white/30">

            <h2 class="text-4xl font-bold text-purple-900 mb-5">
                About This Project
            </h2>

            <p class="text-lg text-purple-700 leading-relaxed">
                NoteVault was built as a backend learning project to explore
                real-world web development concepts including Express.js,
                MongoDB Atlas, Authentication, Authorization, JWT,
                bcrypt, and CRUD Operations.
            </p>

        </div>

    </section>

    <!-- Developer -->
    <section class="max-w-5xl mx-auto px-10 pb-20">

        <div
            class="bg-white/40 backdrop-blur-lg rounded-3xl p-10 shadow-2xl border border-white/30 text-center">

            <h2 class="text-4xl font-bold text-purple-900">
                Built By
            </h2>

            <p class="mt-4 text-2xl font-semibold text-fuchsia-600">
                Atharv Ravindra Sapale
            </p>

            <p class="mt-2 text-purple-700">
                Computer Science Engineering (AIML)
            </p>

            <a href="https://github.com/atharv7237"
                target="_blank"
                class="inline-block mt-6 px-6 py-3 rounded-2xl bg-gradient-to-r from-pink-400 to-fuchsia-500 text-white font-semibold hover:scale-105 transition">
                View GitHub
            </a>

        </div>

    </section>

</body>
</html>
